{
  "name": "diddl-manager",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "prepare": "husky",
    "lint-staged": "bun run --filter @diddl/desktop-app lint-staged && bun run --filter @diddl/scrape-diddl lint-staged",
    "dev:desktop": "bun run --filter @diddl/desktop-app dev",
    "build:desktop": "bun run --filter @diddl/desktop-app build",
    "test:desktop": "bun run --filter @diddl/desktop-app test:unit",
    "dev:website-svelte": "bun run --filter @diddl/website-svelte dev",
    "dev:website-solid-claude": "bun run --filter @diddl/website-solid-claude dev",
    "dev:website-solid-codex": "bun run --filter @diddl/website-solid-codex dev"
  },
  "devDependencies": {
    "husky": "^9.1.7"
  },
  "trustedDependencies": [
    "@clerk/shared",
    "@diddl/desktop-app",
    "@diddl/website-svelte",
    "@parcel/watcher",
    "browser-tabs-lock",
    "bufferutil",
    "core-js",
    "electron-winstaller",
    "esbuild",
    "msgpackr-extract",
    "utf-8-validate"
  ]
}
