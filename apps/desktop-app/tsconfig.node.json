{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": [
    "electron.vite.config.*",
    "src/main/**/*",
    "src/preload/**/*",
    "src/shared/**/*",
    "unit-test/test-setup.ts"
  ],
  "compilerOptions": {
    "composite": true,
    "types": ["electron-vite/node", "bun-types"],
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true
  }
}
