{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "src/renderer/src/env.d.ts",
    "src/renderer/src/**/*",
    "src/renderer/src/**/*.tsx",
    "src/preload/*.d.ts",
    "src/shared/*.ts",
    "src/main/**/*",
    "src/main/database/diddls.json"
  ],
  "exclude": ["src/main/index.ts"],
  "compilerOptions": {
    "moduleResolution": "bundler",
    "composite": true,
    "jsxImportSource": "solid-js",
    "paths": {
      "@renderer/*": ["./src/renderer/src/", "./src/renderer/src/*"],
      "@shared": ["./src/shared", "./src/shared/*"],
      "@assets/*": ["./src/renderer/assets/*"]
    },
    "outDir": "out-tsc/web"
  }
}
