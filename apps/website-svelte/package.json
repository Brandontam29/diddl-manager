{
  "name": "@diddl/website-svelte",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "USE_LOCAL_CONVEX=true vite dev",
    "dev:hosted": "vite dev",
    "convex:dash": "docker run --rm -p 6791:6791 -e NEXT_PUBLIC_DEPLOYMENT_URL=http://127.0.0.1:3210 ghcr.io/get-convex/convex-dashboard:latest",
    "convex:gen": "CONVEX_AGENT_MODE=anonymous convex codegen",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "bun run typecheck",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "oxlint --config ../../.oxlintrc.json src scripts",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json && oxlint --config ../../.oxlintrc.json --tsconfig tsconfig.json --type-aware --type-check src scripts",
    "format": "oxfmt --config ../../.oxfmtrc.json .",
    "seed:data": "bun run scripts/seed-data.ts",
    "seed:images": "bun run scripts/seed-images.ts"
  },
  "dependencies": {
    "@clerk/backend": "^3.2.0",
    "@clerk/clerk-js": "^6.3.0",
    "@clerk/ui": "^1.2.1",
    "@effect/platform-node": "^4.0.0-beta.31",
    "convex": "^1.33.0",
    "convex-helpers": "^0.1.114",
    "convex-svelte": "^0.0.12",
    "convex-vite-plugin": "^0.4.0",
    "effect": "^4.0.0-beta.31",
    "runed": "^0.37.1"
  },
  "devDependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@internationalized/date": "^3.12.0",
    "@lucide/svelte": "^1.7.0",
    "@sveltejs/adapter-vercel": "^6.3.1",
    "@sveltejs/kit": "^2.50.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^24",
    "bits-ui": "^2.16.3",
    "clsx": "^2.1.1",
    "lucide-svelte": "^1.0.1",
    "mode-watcher": "^1.1.0",
    "shadcn-svelte": "^1.2.7",
    "svelte": "^5.51.0",
    "svelte-check": "^4.4.2",
    "svelte-sonner": "^1.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "vite": "^7.3.1",
    "vite-plugin-devtools-json": "^1.0.0"
  }
}
