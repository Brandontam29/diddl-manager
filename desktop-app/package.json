{
  "name": "diddl-manager",
  "version": "1.13.4",
  "description": "App to manage your Diddls",
  "main": "./out/main/index.js",
  "author": "Brandontam29",
  "homepage": "https://electron-vite.org",
  "type": "module",
  "scripts": {
    "format": "prettier --write .",
    "lint": "oxlint --type-aware ./src/",
    "typecheck:node": "tsgolint --tsconfig tsconfig.node.json --deny-warnings",
    "typecheck:web": "tsgolint --tsconfig tsconfig.node.json --deny-warnings",
    "typecheck": "bun run typecheck:node && bun run typecheck:web",
    "preview": "electron-vite preview",
    "start": "electron-vite dev --watch",
    "dev": "electron-vite dev --watch",
    "build": "electron-vite build",
    "build:local:win": "electron-vite build && electron-builder --win",
    "build:local:mac": "electron-vite build && electron-builder --mac",
    "build:local:linux": "electron-vite build && electron-builder --linux",
    "build:win": "bun run build && electron-builder --win --publish always",
    "build:mac": "electron-vite build && electron-builder --mac --publish always",
    "build:linux": "electron-vite build && electron-builder --linux --publish always",
    "postinstall": "electron-builder install-app-deps",
    "test:e2e": "playwright test",
    "test:unit": "bun test --preload ./unit-test/test-setup.ts src/"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@kobalte/core": "^0.13.11",
    "@solid-primitives/intersection-observer": "^2.2.4",
    "@solid-primitives/media": "^2.3.5",
    "@solid-primitives/scheduled": "^1.5.3",
    "@solidjs/router": "^0.15.4",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/solid-form": "^1.28.5",
    "adm-zip": "^0.5.16",
    "better-sqlite3": "^12.8.0",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "eslint-plugin-neverthrow": "^1.1.4",
    "kysely": "^0.28.13",
    "kysely-plugin-serialize": "^0.8.2",
    "lucide-solid": "^0.441.0",
    "motion": "^12.38.0",
    "neverthrow": "^8.2.0",
    "solid-icons": "^1.2.0",
    "tailwind-merge": "^2.6.1",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@playwright/test": "^1.58.2",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^22.19.15",
    "autoprefixer": "^10.4.27",
    "bun-types": "^1.3.11",
    "electron": "^37.10.3",
    "electron-builder": "^26.8.1",
    "electron-playwright-helpers": "^2.1.0",
    "electron-vite": "^4.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-oxlint": "^1.56.0",
    "eslint-plugin-solid": "^0.14.5",
    "husky": "^9.1.7",
    "kysely-codegen": "^0.19.0",
    "lint-staged": "^16.4.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.10.1",
    "playwright": "^1.58.2",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "solid-js": "^1.9.11",
    "tailwind-scrollbar": "^4.0.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-solid": "^2.11.11",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  }
}
