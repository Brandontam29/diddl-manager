{
  "name": "diddl-manager",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "prepare": "husky",
    "format": "oxfmt --config ./.oxfmtrc.json .",
    "format:check": "oxfmt --config ./.oxfmtrc.json --check .",
    "lint-staged": "lint-staged",
    "lint:desktop": "bun run --filter @diddl/desktop-app lint",
    "lint:website-svelte": "bun run --filter @diddl/website-svelte lint",
    "lint:data-migrations": "bun run --filter @diddl/data-migrations lint",
    "lint:scrape-diddl": "bun run --filter @diddl/scrape-diddl lint",
    "typecheck:desktop": "bun run --filter @diddl/desktop-app --elide-lines=0 typecheck",
    "typecheck:website-svelte": "bun run --filter @diddl/website-svelte typecheck",
    "typecheck:data-migrations": "bun run --filter @diddl/data-migrations typecheck",
    "typecheck:scrape-diddl": "bun run --filter @diddl/scrape-diddl typecheck",
    "dev:desktop": "bun run --filter @diddl/desktop-app --elide-lines=0 dev",
    "build:desktop": "bun run --filter @diddl/desktop-app build",
    "test:desktop": "bun run --filter @diddl/desktop-app test:unit",
    "dev:website-svelte": "bun run --filter @diddl/website-svelte dev"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "oxlint-tsgolint": "^0.20.0"
  },
  "lint-staged": {
    "**/*": "oxfmt --config ./.oxfmtrc.json --no-error-on-unmatched-pattern"
  },
  "packageManager": "bun@1.3.10",
  "trustedDependencies": [
    "@clerk/shared",
    "@diddl/desktop-app",
    "@diddl/website-svelte",
    "@parcel/watcher",
    "browser-tabs-lock",
    "bufferutil",
    "core-js",
    "electron-winstaller",
    "esbuild",
    "msgpackr-extract",
    "utf-8-validate"
  ]
}
