{
  "name": "@diddl/desktop-app",
  "version": "1.17.0",
  "description": "App to manage your Diddls",
  "main": "./out/main/index.js",
  "author": "Brandontam29",
  "homepage": "https://electron-vite.org",
  "private": true,
  "type": "module",
  "scripts": {
    "format": "oxfmt --config ../../.oxfmtrc.json .",
    "lint:node": "oxlint --config ../../.oxlintrc.json electron.vite.config.ts src/main src/preload src/shared unit-test",
    "lint:web": "oxlint --config ../../.oxlintrc.json src/renderer/src src/preload src/shared",
    "lint": "bun run lint:node && bun run lint:web",
    "typecheck:node": "oxlint --config ../../.oxlintrc.json --tsconfig tsconfig.node.json --type-aware --type-check electron.vite.config.ts src/main src/preload src/shared unit-test",
    "typecheck:web": "oxlint --config ../../.oxlintrc.json --tsconfig tsconfig.web.json --type-aware --type-check src/renderer/src src/preload src/shared",
    "typecheck": "bun run typecheck:node && bun run typecheck:web",
    "preview": "electron-vite preview",
    "start": "electron-vite dev --watch",
    "dev": "electron-vite dev --watch",
    "build": "electron-vite build",
    "build:local:win": "electron-vite build && electron-builder --win",
    "build:local:mac": "electron-vite build && electron-builder --mac",
    "build:local:linux": "electron-vite build && electron-builder --linux",
    "build:win": "bun run build && electron-builder --win --publish always",
    "build:mac": "electron-vite build && electron-builder --mac --publish always",
    "build:linux": "electron-vite build && electron-builder --linux --publish always",
    "postinstall": "electron-builder install-app-deps",
    "test:e2e": "playwright test",
    "test:unit": "bun test --preload ./unit-test/test-setup.ts src/"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@kobalte/core": "^0.13.11",
    "@solid-primitives/intersection-observer": "^2.2.4",
    "@solid-primitives/media": "^2.3.5",
    "@solid-primitives/scheduled": "^1.5.3",
    "@solidjs/router": "^0.15.4",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/solid-form": "^1.28.5",
    "@trpc/client": "10",
    "@trpc/server": "10",
    "adm-zip": "^0.5.16",
    "better-sqlite3": "^12.8.0",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-store": "^11.0.2",
    "electron-trpc": "0.7.1",
    "electron-updater": "^6.8.3",
    "kysely": "^0.28.14",
    "kysely-plugin-serialize": "^0.8.2",
    "lucide-solid": "^0.441.0",
    "motion": "^12.38.0",
    "neverthrow": "^8.2.0",
    "solid-icons": "^1.2.0",
    "tailwind-merge": "^2.6.1",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@playwright/test": "^1.58.2",
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^22.19.15",
    "autoprefixer": "^10.4.27",
    "baseline-browser-mapping": "^2.10.11",
    "bun-types": "^1.3.11",
    "electron": "^37.10.3",
    "electron-builder": "^26.8.1",
    "electron-playwright-helpers": "^2.1.0",
    "electron-vite": "^4.0.1",
    "kysely-codegen": "^0.19.0",
    "playwright": "^1.58.2",
    "postcss": "^8.5.8",
    "solid-js": "^1.9.11",
    "tailwind-scrollbar": "^4.0.2",
    "tailwindcss": "^4.2.2",
    "vite": "^7.3.1",
    "vite-plugin-solid": "^2.11.11",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "trustedDependencies": [
    "better-sqlite3",
    "electron"
  ]
}
